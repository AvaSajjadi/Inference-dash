#!/usr/bin/env Rscript
# run_cie_pkg.R — run the *CIE* package (umbibio/CIE-R-Package) on your files
suppressPackageStartupMessages(library(CIE))
sig_path <- "/home/ava/Downloads/myc_sig_clean.txt"
rel_path <- "/home/ava/inference_dash/networks/three_tissues.rels"
stopifnot(file.exists(sig_path))
stopifnot(file.exists(rel_path))
cat("[CIE] version:", as.character(packageVersion("CIE")), "\n")
cat("[CIE] library:", find.package("CIE"), "\n")
cat("[CIE] sig_path:", sig_path, "\n")
cat("[CIE] rel_path:", rel_path, "\n\n")
# ---- Validate signature file (must be a PATH when userFile=TRUE) ----
sig <- read.table(sig_path, header = TRUE, sep = "\t", stringsAsFactors = FALSE, check.names = FALSE)
# Accept either:
#   (A) gene/logFC/pval
#   (B) entrez/fc/pval (your myc_sig_clean.txt)
cn <- tolower(colnames(sig))
colnames(sig) <- cn
if (all(c("entrez","fc","pval") %in% cn)) {
  sig <- sig[, c("entrez","pval","fc")]
  colnames(sig) <- c("gene","pval","logFC")   # what runCIE expects when logFC=TRUE
} else if (all(c("gene","logfc","pval") %in% cn)) {
  sig <- sig[, c("gene","pval","logfc")]
  colnames(sig) <- c("gene","pval","logFC")
} else {
  stop("Signature file must have columns (entrez, fc, pval) OR (gene, logFC, pval). Found: ",
       paste(colnames(sig), collapse=", "))
}
# write a cleaned temp signature file to guarantee the exact header/format CIE expects
sig_tmp <- tempfile("cie_sig_", fileext = ".tsv")
write.table(sig, sig_tmp, sep = "\t", quote = FALSE, row.names = FALSE)
cat("[CIE] wrote normalized signature ->", sig_tmp, "\n")
# ---- Validate rels file (must be a PATH when userFile=TRUE) ----
rels <- read.table(rel_path, header = TRUE, sep = "\t", stringsAsFactors = FALSE, check.names = FALSE)
req_cols <- c("uid","srcuid","trguid","type")
if (!all(req_cols %in% colnames(rels))) {
  stop("rels file must include columns: ", paste(req_cols, collapse=", "),
       ". Found: ", paste(colnames(rels), collapse=", "))
}
cat("[CIE] rels rows:", nrow(rels), "\n\n")
# ---- RUN CIE (THIS is the correct API; do NOT pass data.frames to ents/rels) ----
res <- runCIE(
  databaseType = "ChIP",
  userFile     = TRUE,
  ents         = sig_tmp,      # must be a FILE PATH when userFile=TRUE
  rels         = rel_path,     # must be a FILE PATH when userFile=TRUE
  methods      = "Fisher",
  p.thresh     = 0.01,
  fc.thresh    = log(1.5),
  logFC        = TRUE,
  verbose      = TRUE
)
cat("\n[CIE] res names:\n")
print(names(res))
# Try the common output slots
if ("results" %in% names(res)) {
  cat("\n[CIE] head(res$results):\n")
  print(utils::head(res$results, 10))
}
if ("tfs" %in% names(res)) {
  cat("\n[CIE] head(res$tfs):\n")
  print(utils::head(res$tfs, 10))
}
if ("edges" %in% names(res)) {
  cat("\n[CIE] head(res$edges):\n")
  print(utils::head(res$edges, 10))
}
# Save whatever exists
out_dir <- "/home/ava/inference_dash/results"
dir.create(out_dir, showWarnings = FALSE, recursive = TRUE)
if ("results" %in% names(res)) write.csv(res$results, file.path(out_dir, "cie_pkg_results.csv"), row.names = FALSE)
if ("tfs" %in% names(res))     write.csv(res$tfs,     file.path(out_dir, "cie_pkg_tfs.csv"),     row.names = FALSE)
if ("edges" %in% names(res))   write.csv(res$edges,   file.path(out_dir, "cie_pkg_edges.csv"),   row.names = FALSE)
cat("\n[CIE] done. wrote outputs (if present) into:", out_dir, "\n")
q()
